# AI API (OpenAI-compatible endpoint)
AI_BASE_URL=https://creavoo-9router.fly.dev/v1
AI_API_KEY=sk-xxxxxxxxxxxxxx
AI_MODEL=creavoo-combo

# GitHub (untuk trigger Actions)
GITHUB_REPO=username/repo-name
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxx

# TTS voice (edge-tts)
TTS_VOICE=id-ID-ArdiNeural

# MinIO (S3-compatible, untuk simpan video/gambar hasil render)
# Bucket harus punya Anonymous Access Rule "readonly" (prefix kosong) supaya file bisa diakses publik
MINIO_ENDPOINT=https://minio-api.namadomain.com
MINIO_ACCESS_KEY=xxxxxxxxxxxxxx
MINIO_SECRET_KEY=xxxxxxxxxxxxxx
MINIO_BUCKET=nama-bucket
MINIO_REGION=us-east-1
MINIO_PUBLIC_URL=https://minio-api.namadomain.com

# Public (exposed ke browser)
NEXT_PUBLIC_GITHUB_REPO=username/repo-name
